<div style="font-family: sans-serif; color: #330000; border: 1px solid #eee; max-width: 600px; margin: auto;">
    <div style="background: #ff3300; padding: 20px; text-align: center;">
        <h2 style="color: white; margin: 0; text-transform: uppercase;">Nouveau Contact Site Web</h2>
    </div>
    
    <div style="padding: 30px;">
        <p><strong>De :</strong> {{ name }} ({{ visitorEmail }})</p>
        <p><strong>Sujet :</strong> {{ subject }}</p>
        <hr style="border: none; border-top: 1px solid #eee; margin: 20px 0;">
        <p style="white-space: pre-line;"><strong>Message :</strong><br><br>{{ message }}</p>
    </div>
    
    <div style="background: #f4f4f4; padding: 15px; text-align: center; font-size: 11px; color: #999;">
        Ce message a été envoyé depuis le formulaire de contact de The Moroccan Network.
    </div>
</div>